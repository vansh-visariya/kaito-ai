# Required — obtain from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Required — obtain from https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — obtain from https://smith.langchain.com/  (enables LangSmith tracing)
# LANGCHAIN_API_KEY=your_langchain_api_key_here

# Required on Python 3.13+ with chromadb — fixes "Descriptors cannot be created directly" error.
# This is also set automatically via .venv/Lib/site-packages/sitecustomize.py.
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python
